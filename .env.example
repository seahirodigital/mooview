# MooViewサーバーから接続するMoomooゲートウェイ
MOOMOO_GATEWAY_URL=http://127.0.0.1:8787

# 外部公開時は十分に長いランダム値を設定し、Vercel側にも同じ値を登録する
MOOMOO_GATEWAY_KEY=

# ローカル開発時のゲートウェイ自動起動
MOOMOO_GATEWAY_AUTOSTART=true
MOOMOO_PYTHON=C:\Users\mahha\AppData\Local\mooview\venv\Scripts\python.exe

# Moomoo OpenDの公式Socket API
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111

# Pythonゲートウェイの待受設定
MOOMOO_GATEWAY_HOST=127.0.0.1
MOOMOO_GATEWAY_PORT=8787

# Gemini APIキーはサーバー側だけに設定する
GEMINI_API_KEY=
