{
  "name": "react-example",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "setup:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/setup-local-runtime.ps1",
    "install:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-node-local.ps1",
    "tunnel:register": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/register-production-tunnel.ps1",
    "dev": "tsx server.ts",
    "build:web": "vite build",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
